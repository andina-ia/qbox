---
import BaseLayout from '../layouts/BaseLayout.astro';
import { waLink } from '../lib/site.js';
import config from '../data/config.json';

const CATS = {
  modulos: {
    name: 'Módulos', kicker: 'Viviendas · Oficinas · Llave en mano',
    tagline: 'Un módulo. Infinitas posibilidades. Vos elegís para qué usarlo, nosotros lo entregamos listo.',
    heroBg: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=1400&auto=format&fit=crop',
    introTitle: 'Una vivienda u oficina completa, lista para usar.',
    introP1: 'Los módulos qBox se proyectan, fabrican y terminan en taller bajo control de calidad, y se montan en obra en cuestión de días. Resolvemos viviendas, estudios y oficinas con la misma ingeniería sismo resistente.',
    introP2: 'Cada módulo se entrega con terminaciones premium y se adapta a tu terreno, incluso en ubicaciones con desafíos logísticos.',
    features: [
      { n: '01', title: 'Llave en mano', desc: 'Diseño, gestión y construcción integral. Usted elige el lugar.' },
      { n: '02', title: 'Montaje en tiempo récord', desc: 'Fabricación en taller en paralelo a la preparación del terreno.' },
      { n: '03', title: 'Ingeniería sismo resistente', desc: 'Estructura calculada y homologada para zonas sísmicas.' },
      { n: '04', title: 'Terminaciones premium', desc: 'Materiales nobles y aislación de alto estándar.' }
    ],
    images: ['/assets/modulos/20260204_103237.webp', '/assets/modulos/20260204_102714.webp', '/assets/modulos/20260211_112857.webp', '/assets/modulos/20260211_112829.webp', '/assets/modulos/20260204_140942.webp', '/assets/modulos/20260204_140820.webp'],
    waMsg: 'Hola qBox, me interesa la línea de módulos habitables. Quisiera más información.'
  },
  stands: {
    name: 'Stands', kicker: 'Eventos · Ferias · Empresas',
    tagline: 'Stands modulares reutilizables que proyectan tu marca con un estándar premium.',
    heroBg: '/assets/stands/20260506_014651.webp',
    introTitle: 'Tu marca, montada y desmontada sin fricción.',
    introP1: 'Diseñamos y construimos stands modulares para ferias, eventos y espacios corporativos. Sistema reutilizable, transportable y de armado rápido, con la estética cuidada que tu marca merece.',
    introP2: 'Integramos iluminación, mobiliario y gráfica para que el espacio comunique desde el primer minuto.',
    features: [
      { n: '01', title: 'Armado y desarme rápido', desc: 'Sistema modular pensado para la logística de eventos.' },
      { n: '02', title: 'Reutilizable', desc: 'Una inversión que sirve para múltiples ferias y activaciones.' },
      { n: '03', title: 'Identidad de marca', desc: 'Gráfica, iluminación y materiales a medida.' },
      { n: '04', title: 'Estándar premium', desc: 'Terminaciones de showroom, no de feria improvisada.' }
    ],
    images: ['/assets/stands/20260506_014651.webp', '/assets/stands/20260505_204724.webp', '/assets/stands/20260505_230503.webp', '/assets/stands/20260506_005732.webp', '/assets/stands/20260430_182019.webp', '/assets/stands/stand-caprimsa-01.webp', '/assets/stands/stand-caprimsa-02.webp', '/assets/stands/stand-heic-01.webp', '/assets/stands/stand-heic-02.webp'],
    waMsg: 'Hola qBox, me interesa la línea de stands modulares. Quisiera más información.'
  },
  'cocheras-galerias': {
    name: 'Cocheras y Galerías', kicker: 'Semicubiertos',
    tagline: 'Cubiertas y semicubiertos de líneas puras, integrados a tu espacio.',
    heroBg: '/assets/cocheras/cochera_chapa_perforada.webp',
    introTitle: 'Sumá metros cubiertos con diseño, no con un techo más.',
    introP1: 'Cocheras, galerías y semicubiertos resueltos con estructura modular y terminaciones que dialogan con tu vivienda. Protección real con una estética minimalista y cálida.',
    introP2: 'Se contempla un mínimo de 20 m² para optimizar la estructura y el valor por metro cuadrado.',
    features: [
      { n: '01', title: 'Líneas puras', desc: 'Voladizos limpios y cielorrasos de madera o chapa premium.' },
      { n: '02', title: 'Estructura sismo resistente', desc: 'Cálculo homologado para vientos y cargas de la región.' },
      { n: '03', title: 'Integración total', desc: 'Materiales y proporciones que continúan tu vivienda.' },
      { n: '04', title: 'Desde 20 m²', desc: 'Superficie mínima que optimiza el costo por metro.' }
    ],
    images: ['/assets/cocheras/cochera-01-nocturna.webp', '/assets/cocheras/cochera-02-galeria-dia.webp', '/assets/cocheras/cochera-03-motos.webp', '/assets/cocheras/cochera-04-construccion.webp', '/assets/cocheras/cochera-05-blanca.webp', '/assets/cocheras/cochera-06-terraza-deck.webp', '/assets/cocheras/cochera-07-galeria-jardin.webp', '/assets/cocheras/cochera-08-pergola-listones.webp'],
    waMsg: 'Hola qBox, me interesa la línea de cocheras y galerías. Quisiera más información.'
  },
  ampliaciones: {
    name: 'Ampliaciones', kicker: 'Construcción en seco',
    tagline: 'Sumá metros a tu hogar o empresa sin obras eternas ni escombros.',
    heroBg: '/assets/ampliaciones.webp',
    introTitle: 'Más espacio, sin la obra húmeda de siempre.',
    introP1: 'Ampliamos viviendas y locales con sistemas de construcción en seco: rápido, limpio y con mínima interrupción de tu día a día. Dormitorios, oficinas, entrepisos y más.',
    introP2: 'Coordinamos cada etapa para que el resultado se integre sin costuras a lo existente.',
    features: [
      { n: '01', title: 'Construcción en seco', desc: 'Sin escombros ni tiempos de fragüe. Obra limpia.' },
      { n: '02', title: 'Mínima interrupción', desc: 'Seguís usando tu casa o local mientras avanzamos.' },
      { n: '03', title: 'Integración perfecta', desc: 'Terminaciones que continúan lo construido.' },
      { n: '04', title: 'Plazos cortos', desc: 'Prefabricación que acelera cada etapa.' }
    ],
    images: ['/assets/ampliaciones/amp-01-pared-listones.webp', '/assets/ampliaciones/amp-02-frente-nocturno.webp', '/assets/ampliaciones/amp-03-chapa-perforada.webp', '/assets/ampliaciones/amp-04-cielorraso-madera.webp', '/assets/ampliaciones/amp-05-voladizo-obra.webp', '/assets/ampliaciones/amp-06-pergola-vidrio.webp'],
    waMsg: 'Hola qBox, me interesa ampliar mi hogar o local en construcción en seco. Quisiera más información.'
  },
  locales: {
    name: 'Locales comerciales', kicker: 'Retail · Showrooms',
    tagline: 'Locales y showrooms modulares listos para abrir, con identidad de marca.',
    heroBg: '/assets/locales/local_2_fachada_completa.webp',
    introTitle: 'Abrí tu local antes y mejor.',
    introP1: 'Locales comerciales y showrooms modulares pensados para retail: vidriera, layout y terminaciones que potencian la experiencia de compra. Listos para operar en tiempo récord.',
    introP2: 'Soluciones escalables y replicables si tu marca crece o suma puntos de venta.',
    features: [
      { n: '01', title: 'Listo para operar', desc: 'Vidriera, instalaciones y terminaciones resueltas.' },
      { n: '02', title: 'Replicable', desc: 'Ideal para cadenas y multipunto con imagen consistente.' },
      { n: '03', title: 'Experiencia de compra', desc: 'Layout e iluminación pensados para retail.' },
      { n: '04', title: 'Tiempo récord', desc: 'Abrís meses antes que con obra tradicional.' }
    ],
    images: ['/assets/locales/local_2_fachada_completa.webp', '/assets/locales/local_3_porton_grande.webp', '/assets/locales/local_1_detalle_ventanas.webp', '/assets/locales/local_4_calle_arbol.webp', '/assets/locales/local_5_lateral_camioneta.webp'],
    waMsg: 'Hola qBox, me interesa la línea de locales comerciales. Quisiera más información.'
  }
};

const seo = { title: 'qBox' };
const siteConfig = { media: config.media || {}, seo: config.seo || {} };
---

<BaseLayout seo={seo}>
  <section id="cat-hero">
    <div class="cat-hero-bg" id="hero-bg"></div>
    <div class="cat-hero-ov"></div>
    <div class="cat-hero-cnt">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Volver al inicio
      </a>
      <p class="cat-kicker" id="cat-kicker"></p>
      <h1 id="cat-title"></h1>
      <p class="cat-tagline" id="cat-tagline"></p>
    </div>
  </section>

  <section class="sec" style="padding-top:clamp(32px,4vw,48px);">
    <div class="gal-hd rv">
      <div>
        <p class="eye" style="margin-bottom:10px;">Proyectos terminados</p>
        <h2>Nuestro trabajo <em style="font-style:italic;color:var(--accent)">habla solo.</em></h2>
      </div>
      <p class="gal-count" id="gal-count"></p>
    </div>
    <div class="gallery rv" id="gallery"></div>
  </section>

  <section class="sec" style="padding-top:0;background:var(--card);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
    <div class="intro-grid rv" style="padding-top:clamp(48px,6vw,80px);">
      <div>
        <p class="eye" style="margin-bottom:12px;">Por qué elegirnos</p>
        <h2 class="intro-title" id="intro-title"></h2>
        <p class="intro-p" id="intro-p1"></p>
        <p class="intro-p" id="intro-p2"></p>
      </div>
      <div class="features" id="features"></div>
    </div>
  </section>

  <section class="sec">
    <div class="sismo rv">
      <div class="sismo-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FAF9F5" stroke-width="1.6"><path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></svg>
      </div>
      <div>
        <p class="sismo-title">Ingeniería sismo resistente homologada</p>
        <p class="sismo-body">Todas nuestras soluciones se calculan y certifican con ingeniería sismo resistente, capaz de absorber movimientos sísmicos sin comprometer la seguridad ni la integridad del espacio habitable.</p>
      </div>
    </div>

    <div class="cta-box rv d1">
      <div>
        <p class="eye" style="color:rgba(245,244,240,.45);">Siguiente paso</p>
        <h2 id="cta-title"></h2>
        <p id="cta-p"></p>
      </div>
      <div class="cta-btns">
        <a href="#" id="cta-wa" class="btn-p" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
          Solicitar presupuesto
        </a>
        <a href="https://calendly.com/gambettadiegooscar/30min" target="_blank" rel="noopener" class="btn-s" style="border-color:rgba(245,238,220,.25);">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4" width="18" height="18" rx="3"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          Agendar visita
        </a>
      </div>
    </div>
  </section>

  <div class="lb" id="lb" onclick="if(event.target===this)closeLb()">
    <button class="lb-close" onclick="closeLb()">×</button>
    <button class="lb-nav lb-prev" onclick="lbNav(-1)">‹</button>
    <img id="lb-img" src="" alt="" />
    <button class="lb-nav lb-next" onclick="lbNav(1)">›</button>
  </div>

  <script type="application/json" id="categoria-data" set:html={JSON.stringify({ CATS, siteConfig })}></script>
  <script is:inline>
    const { CATS, siteConfig } = JSON.parse(document.getElementById('categoria-data').textContent);
    const slug = (() => { try { const q = new URLSearchParams(window.location.search).get('cat'); if (q && CATS[q]) return q; } catch (e) {} return 'modulos'; })();
    const cat = CATS[slug];

    /* SEO — baked defaults from config, overridable via admin config */
    const seoCfg = (siteConfig.seo || {})[slug] || {};
    document.title = seoCfg.title || cat.name + ' | qBox';
    const setMeta = (name, val) => {
      if (!val) return;
      let m = document.querySelector(`meta[name="${name}"]`);
      if (!m) { m = document.createElement('meta'); m.setAttribute('name', name); document.head.appendChild(m); }
      m.setAttribute('content', val);
    };
    setMeta('description', seoCfg.desc);
    setMeta('keywords', seoCfg.keywords);

    /* Hero */
    document.getElementById('hero-bg').style.backgroundImage = `url(${cat.heroBg})`;
    document.getElementById('cat-kicker').textContent = cat.kicker;
    document.getElementById('cat-title').innerHTML = cat.name;
    document.getElementById('cat-tagline').textContent = cat.tagline;

    /* Intro */
    document.getElementById('intro-title').textContent = cat.introTitle;
    document.getElementById('intro-p1').textContent = cat.introP1;
    document.getElementById('intro-p2').textContent = cat.introP2;

    /* Features */
    document.getElementById('features').innerHTML = cat.features
      .map((f) => `<div class="feat"><div class="feat-n">${f.n}</div><div class="feat-t">${f.title}</div><div class="feat-d">${f.desc}</div></div>`)
      .join('');

    /* Gallery — admin media overrides defaults */
    const media = (siteConfig.media || {})[slug];
    let imgs = Array.isArray(media) && media.length ? media : cat.images;
    function renderGallery() {
      document.getElementById('gal-count').textContent = imgs.length + ' proyectos';
      document.getElementById('gallery').innerHTML = imgs
        .map((src, i) => `<div class="gal-item" onclick="openLb(${i})"><img src="${src}" alt="${cat.name} qBox ${i + 1}" loading="${i < 4 ? 'eager' : 'lazy'}"></div>`)
        .join('');
    }
    renderGallery();

    /* CTA */
    document.getElementById('cta-title').textContent = '¿Querés saber más sobre nuestros ' + cat.name.toLowerCase() + '?';
    document.getElementById('cta-p').textContent = 'Contactanos por WhatsApp o agendá una visita al showroom para conocer el sistema constructivo en persona.';
    document.getElementById('cta-wa').href = 'https://wa.me/5492644431309?text=' + encodeURIComponent(cat.waMsg);

    /* Lightbox */
    let lbIdx = 0;
    function openLb(i) { lbIdx = i; document.getElementById('lb-img').src = imgs[i]; document.getElementById('lb').classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeLb() { document.getElementById('lb').classList.remove('open'); document.body.style.overflow = ''; }
    function lbNav(dir) { lbIdx = (lbIdx + dir + imgs.length) % imgs.length; document.getElementById('lb-img').src = imgs[lbIdx]; }
    document.addEventListener('keydown', (e) => {
      if (!document.getElementById('lb').classList.contains('open')) return;
      if (e.key === 'ArrowRight') lbNav(1);
      if (e.key === 'ArrowLeft') lbNav(-1);
      if (e.key === 'Escape') closeLb();
    });

    /* Reveals (this page renders content via JS after load) */
    const _cro = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); _cro.unobserve(e.target); } }), { threshold: 0.1 });
    document.querySelectorAll('.rv').forEach((el) => _cro.observe(el));
  </script>

  <style is:global>
    #cat-hero { position: relative; min-height: 36vh; display: flex; align-items: flex-end; overflow: hidden; padding-top: 68px; background: #0E0C0A; }
    .cat-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; opacity: .45; z-index: 0; }
    .cat-hero-ov { position: absolute; inset: 0; background: linear-gradient(to right, rgba(14,12,10,.98) 0%, rgba(14,12,10,.75) 45%, rgba(14,12,10,.2) 100%); z-index: 1; }
    .cat-hero-cnt { position: relative; z-index: 2; padding: clamp(28px,4vw,48px) var(--px); width: 100%; }
    .back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 13.5px; font-weight: 600; color: rgba(245,238,220,.45); text-decoration: none; margin-bottom: 16px; transition: .2s; }
    .back-link:hover { color: rgba(245,238,220,.8); }
    .cat-kicker { font-size: 12px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: rgba(245,238,220,.5); margin-bottom: 10px; }
    #cat-hero h1 { color: #F5EEDC; font-size: clamp(28px,3.5vw,48px); line-height: 1.1; margin-bottom: 10px; }
    #cat-hero h1 em { font-style: normal; color: #A0917F; }
    .cat-tagline { color: rgba(245,238,220,.55); font-size: clamp(14px,1.4vw,16px); max-width: 480px; }

    .sec { padding: clamp(48px,6vw,80px) var(--px); max-width: var(--max); margin: 0 auto; }

    .intro-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: clamp(32px,5vw,64px); align-items: start; }
    .intro-title { font-family: var(--serif); font-size: clamp(20px,2.6vw,34px); line-height: 1.22; margin-bottom: 18px; }
    .intro-p { font-size: 16.5px; line-height: 1.75; color: rgba(30,32,34,.75); margin-bottom: 12px; }
    .features { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 4px; }
    .feat { background: var(--card); border: 1.5px solid var(--border); border-radius: 14px; padding: 18px 20px; transition: .2s; }
    .feat:hover { border-color: rgba(30,32,34,.22); box-shadow: 0 8px 24px -10px rgba(30,32,34,.12); }
    .feat-n { font-family: var(--serif); font-size: 22px; color: var(--accent); margin-bottom: 8px; }
    .feat-t { font-size: 15px; font-weight: 700; color: var(--ink); margin-bottom: 4px; }
    .feat-d { font-size: 14px; color: var(--accent); line-height: 1.55; }

    .gal-hd { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 8px; }
    .gal-count { font-size: 15px; color: var(--accent); }
    .gallery { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
    .gal-item { border-radius: 16px; overflow: hidden; aspect-ratio: 4/5; cursor: zoom-in; position: relative; }
    .gal-item:first-child { grid-column: 1/3; aspect-ratio: 16/9; }
    .gal-item img { width: 100%; height: 100%; object-fit: cover; transition: .4s; }
    .gal-item:hover img { transform: scale(1.04); }
    .gal-item::after { content: ''; position: absolute; inset: 0; background: rgba(30,32,34,0); transition: .2s; }
    .gal-item:hover::after { background: rgba(30,32,34,.06); }

    .lb { display: none; position: fixed; inset: 0; z-index: 300; background: rgba(14,12,10,.96); align-items: center; justify-content: center; }
    .lb.open { display: flex; }
    .lb img { max-height: 90vh; max-width: 88vw; border-radius: 10px; object-fit: contain; }
    .lb-close { position: absolute; top: 20px; right: 24px; color: #F5EEDC; font-size: 34px; cursor: pointer; opacity: .65; transition: .2s; background: none; border: none; line-height: 1; }
    .lb-close:hover { opacity: 1; }
    .lb-nav { position: absolute; top: 50%; transform: translateY(-50%); color: #F5EEDC; font-size: 30px; cursor: pointer; background: rgba(245,238,220,.1); border: none; border-radius: 50%; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; transition: .2s; }
    .lb-nav:hover { background: rgba(245,238,220,.2); }
    .lb-prev { left: 20px; }
    .lb-next { right: 20px; }

    .cta-box { background: var(--ink); border-radius: 24px; padding: clamp(48px,6vw,64px) clamp(32px,4vw,56px); display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; margin-top: clamp(48px,6vw,80px); }
    .cta-box h2 { color: #FAF9F5; max-width: 520px; margin-top: 10px; }
    .cta-box p { color: rgba(245,244,240,.65); margin-top: 10px; font-size: 15px; max-width: 460px; line-height: 1.65; }
    .cta-btns { display: flex; gap: 12px; flex-wrap: wrap; flex-shrink: 0; }

    .sismo { background: var(--ink); border-radius: 16px; padding: 22px 26px; display: flex; gap: 18px; align-items: flex-start; margin-top: 32px; }
    .sismo-icon { width: 42px; height: 42px; border-radius: 50%; background: rgba(245,244,240,.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .sismo-title { font-size: 16px; font-weight: 600; color: #FAF9F5; margin-bottom: 6px; }
    .sismo-body { font-size: 15px; line-height: 1.65; color: rgba(245,244,240,.65); }

    @media (max-width: 900px) {
      .intro-grid { grid-template-columns: 1fr; }
      .gallery { grid-template-columns: repeat(2,1fr); }
      .cta-box { flex-direction: column; align-items: flex-start; }
      .features { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 640px) {
      #cat-hero { min-height: 30vh; }
      .cat-hero-cnt { padding: 24px var(--px) 28px; }
      .sec { padding: 32px var(--px); }
      h2 { font-size: clamp(22px,7vw,28px); }
      .gal-hd { flex-direction: column; align-items: flex-start; gap: 6px; margin-bottom: 16px; }
      .gallery { grid-template-columns: repeat(2,1fr); gap: 8px; }
      .gal-item { border-radius: 10px; }
      .intro-title { font-size: clamp(18px,5.5vw,22px); }
