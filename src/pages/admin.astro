      function renderChart(events) {
        const canvas = document.getElementById('chart-main');
        const empty = document.getElementById('chart-empty');
        if (!canvas) return;
        const days = {};
        const addDay = (date, type) => {
          const d = new Date(date).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit' });
          if (!days[d]) days[d] = { pv: 0, cot: 0, contact: 0 };
          days[d][type]++;
        };
        events.forEach((e) => {
          if (e.type === 'page_view') addDay(e.created_at, 'pv');
          if (e.type === 'cotizador_use') addDay(e.created_at, 'cot');
          if (e.type === 'showroom_click' || e.type === 'whatsapp_click') addDay(e.created_at, 'contact');
        });
        const labels = Object.keys(days).slice(-30);
        if (labels.length < 2) { canvas.style.display = 'none'; empty.style.display = 'block'; return; }
        canvas.style.display = 'block'; empty.style.display = 'none';
        const pvData = labels.map((d) => days[d].pv);
        const cotData = labels.map((d) => days[d].cot);
        const contactData = labels.map((d) => days[d].contact);
        const maxVal = Math.max(...pvData, ...cotData, ...contactData, 1);
        const ctx = canvas.getContext('2d');
        const dpr = window.devicePixelRatio || 1;
        const W = canvas.offsetWidth; const H = 220;
        canvas.width = W * dpr; canvas.height = H * dpr; ctx.scale(dpr, dpr);
        const PAD = { top: 16, right: 12, bottom: 36, left: 36 };
        const cW = W - PAD.left - PAD.right; const cH = H - PAD.top - PAD.bottom;
        ctx.clearRect(0, 0, W, H);
        const gridLines = 4;
        ctx.strokeStyle = 'rgba(30,32,34,.07)'; ctx.lineWidth = 1;
        for (let i = 0; i <= gridLines; i++) {
          const y = PAD.top + (cH / gridLines) * i;
          ctx.beginPath(); ctx.moveTo(PAD.left, y); ctx.lineTo(PAD.left + cW, y); ctx.stroke();
          const val = Math.round(maxVal - (maxVal / gridLines) * i);
          ctx.fillStyle = '#8C7E74'; ctx.font = '11px system-ui'; ctx.textAlign = 'right';
          ctx.fillText(val, PAD.left - 6, y + 4);
        }
        const step = Math.ceil(labels.length / 10);
        ctx.fillStyle = '#8C7E74'; ctx.font = '11px system-ui'; ctx.textAlign = 'center';
        labels.forEach((lbl, i) => {
          if (i % step === 0 || i === labels.length - 1) {
            const x = PAD.left + (i / (labels.length - 1)) * cW;
            ctx.fillText(lbl, x, H - 8);
          }
        });
        const drawSeries = (data, color, alpha) => {
          if (!data.some((v) => v > 0)) return;
          const pts = data.map((v, i) => ({ x: PAD.left + (i / Math.max(labels.length - 1, 1)) * cW, y: PAD.top + cH - (v / maxVal) * cH }));
          ctx.beginPath(); ctx.moveTo(pts[0].x, PAD.top + cH);
          pts.forEach((p) => ctx.lineTo(p.x, p.y));
          ctx.lineTo(pts[pts.length - 1].x, PAD.top + cH); ctx.closePath();
          ctx.fillStyle = color.replace(')', `, ${alpha})`).replace('rgb', 'rgba'); ctx.fill();
          ctx.beginPath();
          pts.forEach((p, i) => (i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y)));
          ctx.strokeStyle = color; ctx.lineWidth = 2; ctx.lineJoin = 'round'; ctx.stroke();
          if (labels.length <= 14) {
            pts.forEach((p) => { ctx.beginPath(); ctx.arc(p.x, p.y, 3.5, 0, Math.PI * 2); ctx.fillStyle = color; ctx.fill(); ctx.strokeStyle = '#FAF9F5'; ctx.lineWidth = 1.5; ctx.stroke(); });
          }
        };
        drawSeries(contactData, 'rgb(160,145,127)', 0.12);
        drawSeries(cotData, 'rgb(140,126,116)', 0.14);
        drawSeries(pvData, 'rgb(30,32,34)', 0.06);
      }

