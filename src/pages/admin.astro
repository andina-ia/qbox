          dateFilter = `&created_at=gte.${since}`;
        }
        try {
          const resp = await fetch(
            `${SB_URL}/rest/v1/events?select=type,metadata,created_at&order=created_at.desc&limit=200${dateFilter}`,
            { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
          );
          if (!resp.ok) throw new Error(await resp.text());
          const events = await resp.json();

          const counts = { page_view: 0, cotizador_use: 0, showroom_click: 0, whatsapp_click: 0 };
          events.forEach((e) => { if (counts[e.type] !== undefined) counts[e.type]++; });

          document.getElementById('n-pv').textContent = counts.page_view.toLocaleString('es-AR');
          document.getElementById('n-cot').textContent = counts.cotizador_use.toLocaleString('es-AR');
          document.getElementById('n-sh').textContent = counts.showroom_click.toLocaleString('es-AR');
          document.getElementById('n-wa').textContent = counts.whatsapp_click.toLocaleString('es-AR');

          const contacts = counts.showroom_click + counts.whatsapp_click;
          const conv = counts.page_view > 0 ? Math.round((contacts / counts.page_view) * 100) : 0;
          document.getElementById('n-conv').textContent = conv + '%';

          const typeCount = {};
          events.filter((e) => e.type === 'cotizador_use' && e.metadata?.type).forEach((e) => {
            const t = e.metadata.type; typeCount[t] = (typeCount[t] || 0) + 1;
