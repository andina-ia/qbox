            const totalCot = Object.values(typeCount).reduce((a, b) => a + b, 0);
            const pct = Math.round((topType[1] / totalCot) * 100);
            document.getElementById('n-top-type').textContent = typeLabels[topType[0]] || topType[0];
            document.getElementById('n-top-type-pct').textContent = pct + '% de las consultas';
          } else {
            document.getElementById('n-top-type').textContent = 'Sin datos';
            document.getElementById('n-top-type-pct').textContent = '';
          }

          const hourCount = {};
          events.filter((e) => e.type === 'page_view').forEach((e) => {
            const h = new Date(e.created_at).getHours(); hourCount[h] = (hourCount[h] || 0) + 1;
          });
          if (Object.keys(hourCount).length > 0) {
            const peakHour = Object.entries(hourCount).sort((a, b) => b[1] - a[1])[0];
            const h = parseInt(peakHour[0]);
            document.getElementById('n-peak').textContent = `${h}:00 – ${h + 1}:00`;
