---
import BaseHead from '../components/BaseHead.astro';
import config from '../data/config.json';
import { withBase } from '../lib/site.js';

const CONFIG_SEED = config;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <BaseHead title="qBox · Panel de administración" />
    <style is:global>
      :root {
        --bg: #F5F4F0; --ink: #1E2022; --accent: #8C7E74;
        --card: #FAF9F5; --border: rgba(30, 32, 34, .12);
        --sans: 'Hanken Grotesk', system-ui, sans-serif;
        --serif: 'Newsreader', Georgia, serif;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: var(--bg); color: var(--ink); font-family: var(--sans); min-height: 100vh; }

      /* LOGIN */
      .login-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
      .login-box { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 40px 36px; width: 100%; max-width: 420px; box-shadow: 0 8px 40px rgba(30,32,34,.08); }
      .login-logo { height: 28px; margin-bottom: 24px; }
      .login-title { font-family: var(--serif); font-size: 22px; margin-bottom: 6px; }
      .login-sub { font-size: 14px; color: var(--accent); margin-bottom: 28px; line-height: 1.5; }
      .login-err { font-size: 13.5px; color: #B4452F; margin-bottom: 14px; }

      /* HEADER */
      #hdr { position: sticky; top: 0; z-index: 50; background: rgba(245,244,240,.95); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
      .hdr-in { max-width: 960px; margin: 0 auto; padding: 0 24px; height: 58px; display: flex; align-items: center; justify-content: space-between; }
      .hdr-left { display: flex; align-items: center; gap: 14px; }
      .hdr-logo { height: 26px; }
      .hdr-title { font-size: 13.5px; font-weight: 600; color: var(--accent); }
      .hdr-right { display: flex; gap: 8px; }

      /* LAYOUT */
      .admin-wrap { max-width: 960px; margin: 0 auto; padding: 32px 24px 80px; }

      /* TABS */
      .tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 36px; }
      .tab { height: 40px; padding: 0 18px; border-radius: 100px; font-size: 13.5px; font-weight: 600; cursor: pointer; transition: .2s; border: 1.5px solid var(--border); background: transparent; color: var(--ink); }
      .tab.active { background: var(--ink); color: #FAF9F5; border-color: var(--ink); }
      .tab:hover:not(.active) { border-color: var(--ink); }

      /* SECTION HEADER */
      .sec-title { font-family: var(--serif); font-size: 22px; margin-bottom: 6px; }
      .sec-sub { font-size: 14px; color: var(--accent); line-height: 1.5; margin-bottom: 28px; }

      /* FORM ELEMENTS */
      .field { margin-bottom: 20px; }
      .lbl { font-size: 12px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--accent); margin-bottom: 7px; display: block; }
      input[type=text], input[type=email], input[type=password], input[type=number], textarea {
        width: 100%; padding: 12px 16px; border-radius: 12px; border: 1.5px solid var(--border);
        background: var(--card); font-family: var(--sans); font-size: 15px; color: var(--ink);
        outline: none; transition: border-color .2s; resize: vertical;
      }
      input:focus, textarea:focus { border-color: var(--ink); }
      textarea { min-height: 100px; line-height: 1.6; }
      .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

      /* BUTTONS */
      .btn { display: inline-flex; align-items: center; gap: 8px; padding: 13px 24px; border-radius: 100px; font-size: 14.5px; font-weight: 600; cursor: pointer; border: none; transition: .2s; }
      .btn-primary { background: var(--ink); color: #FAF9F5; }
      .btn-primary:hover { background: #000; transform: translateY(-1px); }
      .btn-outline { background: transparent; color: var(--ink); border: 1.5px solid var(--border); }
      .btn-outline:hover { border-color: var(--ink); }
      .btn-sm { padding: 7px 14px; font-size: 13px; border-radius: 100px; font-weight: 600; cursor: pointer; border: none; transition: .2s; }
      .btn-danger { background: rgba(180,69,47,.1); color: #B4452F; }
      .btn-danger:hover { background: rgba(180,69,47,.18); }

      /* CLIENTS LIST */
      .clients-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
      .client-item { display: flex; align-items: center; gap: 12px; background: var(--card); border: 1.5px solid var(--border); border-radius: 12px; padding: 10px 14px; transition: .2s; }
      .client-item.inactive { opacity: .5; }
      .client-item.inactive .client-name { text-decoration: line-through; }
      .client-check { width: 20px; height: 20px; border-radius: 6px; border: 1.5px solid var(--border); background: transparent; cursor: pointer; flex-shrink: 0; transition: .2s; display: flex; align-items: center; justify-content: center; }
      .client-check.checked { background: var(--ink); border-color: var(--ink); }
      .client-check.checked::after { content: ''; display: block; width: 5px; height: 9px; border: 2px solid #FAF9F5; border-top: none; border-left: none; transform: rotate(45deg) translateY(-1px); }
      .client-name { flex: 1; font-size: 15px; font-weight: 500; }
      .client-handle { cursor: grab; color: var(--accent); font-size: 16px; user-select: none; }

      /* ADD CLIENT */
      .add-row { display: flex; gap: 10px; }
      .add-row input { flex: 1; }

      /* PILLS */
      .pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
      .pill { height: 34px; padding: 0 14px; border-radius: 100px; font-size: 13px; font-weight: 600; cursor: pointer; transition: .2s; border: 1.5px solid var(--border); background: transparent; color: var(--ink); }
      .pill.active { border-color: var(--accent); background: rgba(140,126,116,.12); }
      .pill:hover:not(.active) { border-color: var(--accent); }

      /* SAVE TOAST */
      #toast { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(80px); background: var(--ink); color: #FAF9F5; padding: 12px 24px; border-radius: 100px; font-size: 14px; font-weight: 600; transition: transform .3s cubic-bezier(.2,.7,.2,1); pointer-events: none; z-index: 999; white-space: nowrap; }
      #toast.show { transform: translateX(-50%) translateY(0); }

      /* PANEL */
      .panel { display: none; }
      .panel.active { display: block; }

      /* KPI */
      .kpi-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 20px; display: flex; flex-direction: column; gap: 4px; }
      .kpi-icon { font-size: 24px; margin-bottom: 4px; }
      .kpi-num { font-family: var(--serif); font-size: 38px; font-weight: 400; color: var(--ink); }
      .kpi-lbl { font-size: 13px; color: var(--accent); font-weight: 500; }
      @media (max-width: 640px) { #kpi-grid { grid-template-columns: repeat(2, 1fr) !important; } }
      @media (max-width: 600px) {
        .grid2 { grid-template-columns: 1fr; }
        .tabs { gap: 6px; }
        .tab { font-size: 12.5px; height: 36px; padding: 0 14px; }
        .admin-wrap { padding: 24px 16px 60px; }
        .login-box { padding: 28px 20px; }
      }
    </style>
  </head>
  <body>
    <!-- LOGIN -->
    <div id="login-screen" class="login-wrap" style="display:none;">
      <div class="login-box">
        <img src={withBase('/assets/qbox-logo-ink.webp')} alt="qBox" class="login-logo" />
        <h1 class="login-title">Panel de administración</h1>
        <p class="login-sub">Ingresá tu correo y la clave de acceso para editar el contenido del sitio.</p>
        <div id="login-err" class="login-err" style="display:none;">Correo o clave incorrectos. Intentá de nuevo.</div>
        <div class="field">
          <label class="lbl" for="inp-email">Correo</label>
          <input type="email" id="inp-email" placeholder="comercial@qboxmodular.com.ar" onkeydown="onEnter(event)" />
        </div>
        <div class="field">
          <label class="lbl" for="inp-pass">Clave</label>
          <input type="password" id="inp-pass" placeholder="••••••••" onkeydown="onEnter(event)" />
        </div>
        <button class="btn btn-primary" style="width:100%;justify-content:center;margin-top:4px;" onclick="doLogin()">Ingresar</button>
        <a href={withBase('/')} style="display:block;text-align:center;margin-top:16px;font-size:13.5px;color:var(--accent);text-decoration:none;">← Volver al sitio</a>
      </div>
    </div>

    <!-- ADMIN -->
    <div id="admin-screen" style="display:none;">
      <header id="hdr">
        <div class="hdr-in">
          <div class="hdr-left">
            <img src={withBase('/assets/qbox-logo-ink.webp')} alt="qBox" class="hdr-logo" />
            <span class="hdr-title">Administración</span>
          </div>
          <div class="hdr-right">
            <a href={withBase('/')} target="_blank" rel="noopener" class="btn btn-outline" style="font-size:13.5px;padding:8px 16px;">Ver sitio ↗</a>
            <button class="btn btn-outline" style="font-size:13.5px;padding:8px 16px;" onclick="doLogout()">Salir</button>
          </div>
        </div>
      </header>

      <div class="admin-wrap">
        <div class="tabs">
          <button class="tab active" onclick="showTab('analytics', this)">Dashboard</button>
          <button class="tab" onclick="showTab('contenido', this)">Contenido</button>
          <button class="tab" onclick="showTab('cotizador', this)">Cotizador</button>
          <button class="tab" onclick="showTab('confian', this)">Confían en nosotros</button>
          <button class="tab" onclick="showTab('seo', this)">SEO</button>
          <button class="tab" onclick="showTab('medios', this)">Medios</button>
        </div>

        <!-- ANALYTICS DASHBOARD -->
        <div id="panel-analytics" class="panel active">
          <p class="sec-title">Dashboard</p>
          <p class="sec-sub">Actividad de los últimos 30 días en el sitio.</p>

          <div style="display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap;">
            <button class="pill active" id="f-7" onclick="setRange(7,this)">Últimos 7 días</button>
            <button class="pill" id="f-30" onclick="setRange(30,this)">30 días</button>
            <button class="pill" id="f-90" onclick="setRange(90,this)">90 días</button>
            <button class="pill" id="f-all" onclick="setRange(0,this)">Todo</button>
            <button class="btn btn-outline" style="margin-left:auto;font-size:13px;padding:7px 16px;" onclick="loadAnalytics()">↻ Actualizar</button>
          </div>

          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:16px;" id="kpi-grid">
            <div class="kpi-card"><div class="kpi-icon">👁</div><div class="kpi-num" id="n-pv">—</div><div class="kpi-lbl">Visitas al sitio</div></div>
            <div class="kpi-card"><div class="kpi-icon">🧮</div><div class="kpi-num" id="n-cot">—</div><div class="kpi-lbl">Usaron el cotizador</div></div>
            <div class="kpi-card"><div class="kpi-icon">📅</div><div class="kpi-num" id="n-sh">—</div><div class="kpi-lbl">Solicitudes de visita</div></div>
            <div class="kpi-card"><div class="kpi-icon">💬</div><div class="kpi-num" id="n-wa">—</div><div class="kpi-lbl">Contactos WhatsApp</div></div>
          </div>

          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px;">
            <div class="kpi-card" style="border-left:3px solid var(--ink);"><div class="kpi-icon">🎯</div><div class="kpi-num" id="n-conv">—</div><div class="kpi-lbl">Tasa de conversión</div><div style="font-size:12px;color:var(--accent);margin-top:4px;">visitas → contacto</div></div>
            <div class="kpi-card" style="border-left:3px solid var(--ink);"><div class="kpi-icon">🏗</div><div class="kpi-num" id="n-top-type" style="font-size:22px;margin-top:4px;">—</div><div class="kpi-lbl">Proyecto más cotizado</div><div style="font-size:12px;color:var(--accent);margin-top:4px;" id="n-top-type-pct"></div></div>
            <div class="kpi-card" style="border-left:3px solid var(--ink);"><div class="kpi-icon">🕐</div><div class="kpi-num" id="n-peak" style="font-size:32px;margin-top:4px;">—</div><div class="kpi-lbl">Horario pico de visitas</div><div style="font-size:12px;color:var(--accent);margin-top:4px;" id="n-peak-sub"></div></div>
          </div>

          <p class="lbl" style="margin-bottom:12px;">Actividad diaria</p>
          <div style="background:var(--card);border:1px solid var(--border);border-radius:16px;padding:24px 20px 16px;margin-bottom:24px;">
            <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:20px;" id="chart-legend">
              <label style="display:flex;align-items:center;gap:6px;font-size:13px;font-weight:600;cursor:pointer;"><span style="width:12px;height:12px;border-radius:50%;background:#1E2022;display:inline-block;"></span> Visitas<input type="checkbox" id="tog-pv" checked style="display:none;" /></label>
              <label style="display:flex;align-items:center;gap:6px;font-size:13px;font-weight:600;cursor:pointer;"><span style="width:12px;height:12px;border-radius:50%;background:#8C7E74;display:inline-block;"></span> Cotizador<input type="checkbox" id="tog-cot" checked style="display:none;" /></label>
              <label style="display:flex;align-items:center;gap:6px;font-size:13px;font-weight:600;cursor:pointer;"><span style="width:12px;height:12px;border-radius:50%;background:#A0917F;display:inline-block;"></span> Contactos<input type="checkbox" id="tog-contact" checked style="display:none;" /></label>
            </div>
            <canvas id="chart-main" style="width:100%;height:220px;display:block;"></canvas>
            <div id="chart-empty" style="display:none;text-align:center;padding:60px 0;color:var(--accent);font-size:14px;">Sin datos suficientes para mostrar el gráfico.</div>
          </div>

          <p class="lbl" style="margin-bottom:12px;">Actividad reciente</p>
          <div style="background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;" id="events-table">
              <thead>
                <tr style="border-bottom:1px solid var(--border);">
                  <th style="text-align:left;padding:12px 16px;font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--accent);">Evento</th>
                  <th style="text-align:left;padding:12px 16px;font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--accent);">Origen</th>
                  <th style="text-align:right;padding:12px 16px;font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--accent);">Fecha</th>
                </tr>
              </thead>
              <tbody id="events-body"><tr><td colspan="3" style="padding:24px;text-align:center;color:var(--accent);font-size:14px;">Cargando...</td></tr></tbody>
            </table>
          </div>
          <p id="events-empty" style="display:none;text-align:center;color:var(--accent);font-size:14px;margin-top:24px;">Sin eventos en este período.</p>
        </div>

        <!-- CONTENIDO -->
        <div id="panel-contenido" class="panel">
          <p class="sec-title">Contenido</p>
          <p class="sec-sub">Textos editables del Home. Los cambios se publican en el sitio en aproximadamente un minuto.</p>
          <div class="field"><label class="lbl" for="f-herosub">Subtítulo del hero</label><textarea id="f-herosub" rows="3"></textarea></div>
          <div class="field"><label class="lbl" for="f-nos1">Quiénes somos · párrafo principal</label><textarea id="f-nos1" rows="4"></textarea></div>
          <div class="field"><label class="lbl" for="f-nos2">Quiénes somos · párrafo secundario</label><textarea id="f-nos2" rows="3"></textarea></div>
          <button class="btn btn-primary" onclick="saveContent()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Guardar contenido
          </button>
        </div>

        <!-- COTIZADOR -->
        <div id="panel-cotizador" class="panel">
          <p class="sec-title">Cotizador</p>
          <p class="sec-sub">Precio base de referencia por m² (USD). Se usa para calcular la estimación en el sitio.</p>
          <div class="grid2">
            <div class="field"><label class="lbl" for="f-modulo">Módulo habitable · USD/m²</label><input type="number" id="f-modulo" min="1" /></div>
            <div class="field"><label class="lbl" for="f-semi">Semicubierto · USD/m²</label><input type="number" id="f-semi" min="1" /></div>
          </div>
          <button class="btn btn-primary" onclick="saveCotizador()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
            Guardar tarifas
          </button>
        </div>

        <!-- CONFÍAN -->
        <div id="panel-confian" class="panel">
          <p class="sec-title">Confían en nosotros</p>
          <p class="sec-sub">Gestioná las marcas que aparecen en la grilla de respaldo. Marcá/desmarcá para mostrar u ocultar. Arrastrá para reordenar.</p>
          <div class="clients-list" id="clients-list"></div>
          <div class="add-row" style="margin-bottom:24px;">
            <input type="text" id="new-client" placeholder="Nombre de la marca..." onkeydown="if(event.key==='Enter')addClient()" />
            <button class="btn btn-primary" onclick="addClient()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Agregar
            </button>
          </div>
          <button class="btn btn-primary" onclick="saveClients()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
            Guardar marcas
          </button>
        </div>

        <!-- SEO -->
        <div id="panel-seo" class="panel">
          <p class="sec-title">SEO</p>
          <p class="sec-sub">Título, descripción y palabras clave por página.</p>
          <div class="pills" id="seo-pills"></div>
          <div class="field"><label class="lbl" id="seo-title-lbl">Título</label><input type="text" id="f-seo-title" /></div>
          <div class="field"><label class="lbl" for="f-seo-desc">Descripción</label><textarea id="f-seo-desc" rows="3"></textarea></div>
          <div class="field"><label class="lbl" for="f-seo-kw">Palabras clave (separadas por coma)</label><textarea id="f-seo-kw" rows="2"></textarea></div>
          <button class="btn btn-primary" onclick="saveSeo()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
            Guardar SEO
          </button>
        </div>

        <!-- MEDIOS -->
        <div id="panel-medios" class="panel">
          <p class="sec-title">Medios</p>
          <p class="sec-sub">Subí fotos para cada categoría. Se guardan directamente en el repositorio y aparecen en la galería del sitio.</p>
          <div class="pills" id="media-pills"></div>
          <div id="drop-zone" onclick="document.getElementById('file-input').click()"
            style="border:2px dashed var(--border);border-radius:16px;padding:40px 24px;text-align:center;cursor:pointer;transition:.2s;margin-bottom:20px;background:var(--card);"
            ondragover="event.preventDefault();this.style.borderColor='var(--ink)'"
            ondragleave="this.style.borderColor='var(--border)'"
            ondrop="handleDrop(event)">
            <div style="font-size:32px;margin-bottom:10px;">📷</div>
            <p style="font-size:15px;font-weight:600;color:var(--ink);margin-bottom:4px;">Arrastrá fotos o hacé clic para seleccionar</p>
            <p style="font-size:13px;color:var(--accent);">JPG, PNG, WebP · máx 5 MB por imagen</p>
            <input type="file" id="file-input" multiple accept="image/*" style="display:none;" onchange="handleFiles(this.files)" />
          </div>
          <div id="upload-queue" style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;"></div>
          <div id="existing-images" style="margin-bottom:24px;"></div>
        </div>
      </div>
    </div>

    <div id="toast">✓ Guardado</div>

    <script type="application/json" id="admin-data" set:html={JSON.stringify(CONFIG_SEED)}></script>
    <script is:inline>
      /* ===== CONFIG ===== */
      const CONFIG_SEED = JSON.parse(document.getElementById('admin-data').textContent);
      const PASS = 'qbox2026';
      const EMAIL = 'comercial@qboxmodular.com.ar';

      const DEF = {
        heroSub: 'Diseñamos, gestionamos y construimos su espacio con ingeniería sismo resistente.',
        nosotrosP1: 'En qBox adaptamos y flexibilizamos la forma de construir. Nacimos en San Juan durante la pandemia con un objetivo claro: ofrecer espacios habitables en tiempo récord, en lugares con desafíos logísticos y con la mejor relación precio–calidad.',
        nosotrosP2: 'Nos diferenciamos por nuestra localía, compromiso y transparencia. Cada proyecto lo desarrollamos en conjunto con nuestros clientes, asegurando soluciones eficientes y personalizadas.',
        rateModulo: 640,
        rateSemi: 135,
        clients: [
          { name: 'Mapal', active: true }, { name: 'Sigma', active: true }, { name: 'MTZ Transporte', active: true },
          { name: 'Logística Empresaria', active: true }, { name: 'Bulonería Mitre', active: true }, { name: 'Proyecto Altar', active: true },
          { name: 'Austral Gold', active: true }, { name: 'Caposo', active: true }, { name: 'Linked', active: true },
          { name: 'Tip Top', active: true }, { name: 'Starlink Monitoreo', active: true }
        ]
      };

      const SEO_PAGES = [
        ['inicio', 'Inicio'], ['modulos', 'Módulos'], ['stands', 'Stands'],
        ['cocheras-galerias', 'Cocheras y Galerías'], ['ampliaciones', 'Ampliaciones'], ['locales', 'Locales']
      ];
      const SEO_DEF = {
