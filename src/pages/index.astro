---
import BaseLayout from '../layouts/BaseLayout.astro';
import config from '../data/config.json';

const seo = config.seo.inicio;
const content = config.content;
const rateModulo = config.cotizador.rateModulo;
const rateSemi = config.cotizador.rateSemi;
const clients = config.clients.filter((c) => c.active && c.name);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'qBox Construcciones Modulares',
  description:
    'Empresa de construcción modular y en seco en San Juan, Argentina. Viviendas, oficinas, cocheras, ampliaciones y locales comerciales sismo resistentes.',
  url: 'https://qbox-five.vercel.app',
  telephone: '+5492644431309',
  email: 'comercial@qboxmodular.com.ar',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Rivadavia',
    addressRegion: 'San Juan',
    addressCountry: 'AR'
  },
  geo: { '@type': 'GeoCoordinates', latitude: -31.5375, longitude: -68.5364 },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '09:00',
    closes: '18:00'
  },
  areaServed: ['San Juan', 'Mendoza', 'San Luis', 'La Rioja', 'Cuyo'],
  priceRange: '$$',
  image: 'https://qbox-five.vercel.app/assets/modulo-nosotros.webp'
};
---

<BaseLayout seo={seo} home={true}>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <meta name="author" content="qBox Construcciones Modulares" />
    <meta name="geo.region" content="AR-J" />
    <meta name="geo.placename" content="San Juan, Argentina" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://qbox-five.vercel.app/" />
    <meta property="og:title" content="qBox · Construcción Modular y en Seco San Juan" />
    <meta
      property="og:description"
      content="Viviendas, oficinas, cocheras y ampliaciones sismo resistentes listas para habitar en San Juan. Más de 120 proyectos entregados."
    />
    <meta property="og:image" content="https://qbox-five.vercel.app/assets/modulo-nosotros.webp" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="qBox Construcciones Modulares" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="qBox · Construcción Modular San Juan" />
    <meta
      name="twitter:description"
      content="Viviendas y estructuras modulares premium sismo resistentes en San Juan, Argentina."
    />
    <meta name="twitter:image" content="https://qbox-five.vercel.app/assets/modulo-nosotros.webp" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- HERO -->
  <section id="hero">
    <video id="hero-vid" autoplay muted loop playsinline preload="none" poster="/assets/modulo-nosotros.webp">
      <source src="/assets/hero.mp4" type="video/mp4" />
    </video>
    <div id="hero-vid-fade"></div>
    <div class="hero-ov"></div>
    <div class="hero-ov-top"></div>
    <div class="hero-cnt">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        <span class="hero-badge-txt">San Juan</span>
      </div>
      <h1>Construimos espacios para <em>vivir, trabajar y producir.</em></h1>
      <p class="body hero-sub">{content.heroSub}</p>
      <div class="ctas">
        <a href="https://calendly.com/gambettadiegooscar/30min" target="_blank" rel="noopener" class="btn-p">
          Agendar Visita Showroom
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="#soluciones" class="btn-s">Explorar Soluciones</a>
      </div>
    </div>
  </section>

  <!-- SOLUCIONES -->
  <section id="soluciones" class="sec">
    <div class="pub-hd rv">
      <div>
        <p class="eye">Soluciones a medida</p>
        <h2 style="margin-top:8px;">¿Qué necesita construir?</h2>
      </div>
      <p>Dos caminos, un mismo estándar premium.</p>
    </div>
    <div class="pub-grid">
      <a href="/soluciones?tipo=residencial" class="pub-card rv d1">
        <div class="pub-img"><img src="/assets/residencial.webp" alt="Desarrollos residenciales" loading="lazy" /></div>
        <div class="pub-body">
          <p class="pub-kicker">Para vivir</p>
          <h3>Desarrollos Residenciales</h3>
          <p>Casas, estudios y quinchos diseñados para habitar con confort, en tiempo récord.</p>
          <span class="pub-link">Ver soluciones <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
      <a href="/soluciones?tipo=corporativo" class="pub-card rv d2">
        <div class="pub-img"><img src="/assets/corporativo-modulo-negro.webp" alt="Soluciones corporativas" loading="lazy" /></div>
        <div class="pub-body">
          <p class="pub-kicker">Para operar</p>
          <h3>Soluciones Corporativas</h3>
          <p>Oficinas, obradores, infraestructura y soluciones para minería en entornos exigentes.</p>
          <span class="pub-link">Ver soluciones <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
    </div>
    <div class="sismo rv">
      <div class="sismo-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FAF9F5" stroke-width="1.6"><path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></svg>
      </div>
      <div>
        <p class="sismo-title">Ingeniería sismo resistente homologada</p>
        <p class="sismo-body">Todas nuestras soluciones —residenciales y corporativas— se calculan y certifican con ingeniería sismo resistente, capaz de absorber movimientos sísmicos sin comprometer la seguridad ni la integridad del espacio habitable.</p>
      </div>
    </div>
  </section>

  <!-- NOSOTROS -->
  <section id="nosotros">
    <div class="sec">
      <div class="about-hd rv">
        <p class="eye">Quiénes somos</p>
        <p class="eye">San Juan · Argentina</p>
      </div>
      <div class="about-grid">
        <div class="rv d1">
          <hr style="width:40px;border:none;border-top:2px solid var(--accent);margin-bottom:24px;" />
          <p class="about-p1">{content.nosotrosP1}</p>
          <p class="about-p2">{content.nosotrosP2}</p>
          <p class="val-title">Nuestros valores</p>
          <ul class="val-list">
            <li>Honestidad</li>
            <li>Compromiso con el cliente</li>
            <li>Predisposición al trabajo en equipo</li>
          </ul>
        </div>
        <div class="about-img rv d2">
          <img src="/assets/modulo-nosotros-clean.webp" alt="Módulo qBox al atardecer" loading="lazy" />
          <div class="about-img-ov"></div>
        </div>
      </div>
      <div class="stats rv">
        <div class="stat"><div class="stat-n" data-count="120" data-suffix="+">0</div><div class="stat-l">Proyectos entregados</div></div>
        <div class="stat"><div class="stat-n" data-count="45">0</div><div class="stat-l">Días de montaje promedio</div></div>
        <div class="stat"><div class="stat-n" data-count="5" data-suffix="+">0</div><div class="stat-l">Años de experiencia</div></div>
        <div class="stat" style="border-right:none;"><div class="stat-n" data-count="3">0</div><div class="stat-l">Provincias · Cuyo</div></div>
      </div>
    </div>
  </section>

  <!-- PROYECTOS BENTO -->
  <section id="proyectos" class="sec">
    <div class="bento-hd rv">
      <div>
        <p class="eye">Nuestros proyectos</p>
        <h2 style="margin-top:8px;">Proyectos <em style="font-style:italic;color:var(--accent)">terminados.</em></h2>
      </div>
      <p style="font-size:15px;">Explorá cada línea de trabajo.</p>
    </div>
    <div class="bento-grid">
      <a href="/categoria?cat=modulos" class="bento-card bento-big rv d1" style="background-image:url(https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=1300&auto=format&fit=crop)">
        <div class="bento-ov"></div>
        <div class="bento-body">
          <p class="bento-kicker">Viviendas · Oficinas</p>
          <p class="bento-name">Módulos</p>
          <span class="bento-link">Ver proyectos <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
      <a href="/categoria?cat=stands" class="bento-card bento-sm rv d2" style="background-image:url(/assets/stand-emergencias.webp)">
        <div class="bento-ov"></div>
        <div class="bento-body">
          <p class="bento-kicker">Eventos · Ferias</p>
          <p class="bento-name">Stands</p>
          <span class="bento-link">Ver proyectos <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
      <a href="/categoria?cat=cocheras-galerias" class="bento-card bento-sm rv d3" style="background-image:url(/assets/cochera-bento.webp)">
        <div class="bento-ov"></div>
        <div class="bento-body">
          <p class="bento-kicker">Semicubiertos</p>
          <p class="bento-name">Cocheras y Galerías</p>
          <span class="bento-link">Ver proyectos <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
      <a href="/categoria?cat=ampliaciones" class="bento-card bento-sm rv d1" style="background-image:url(/assets/ampliaciones.webp)">
        <div class="bento-ov"></div>
        <div class="bento-body">
          <p class="bento-kicker">Construcción en seco</p>
          <p class="bento-name">Ampliaciones</p>
          <span class="bento-link">Ver proyectos <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
      <a href="/categoria?cat=locales" class="bento-card bento-sm rv d2" style="background-image:url(/assets/locales-comerciales.webp)">
        <div class="bento-ov"></div>
        <div class="bento-body">
          <p class="bento-kicker">Retail · Showrooms</p>
          <p class="bento-name">Locales comerciales</p>
          <span class="bento-link">Ver proyectos <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </div>
      </a>
    </div>
  </section>

  <!-- RESPALDO -->
  <section id="respaldo">
    <div class="sec">
      <div class="rv" style="text-align:center;">
        <p class="eye">Confían en nosotros</p>
        <h2 style="margin-top:10px;">Empresas que ya construyeron con qBox.</h2>
      </div>
      <div class="logos rv">
        {clients.map((cl) => <div class="logo-i">{cl.name}</div>)}
      </div>
    </div>
  </section>

  <!-- COTIZADOR -->
  <section id="precios" class="sec">
    <div class="rv" style="text-align:center;max-width:600px;margin:0 auto 36px;">
      <p class="eye">Cotizador online</p>
      <h2 style="margin-top:10px;">Estime su proyecto en segundos.</h2>
      <p class="body" style="margin-top:12px;">Configure el tipo, la superficie y la terminación; le damos un valor de referencia.</p>
    </div>
    <div class="cot-grid rv">
      <div class="cot-ctrl">
        <div>
          <p class="cot-lbl">1 · Tipo de proyecto</p>
          <div class="type-opts">
            <button class="type-opt sel" id="t-modulo" onclick="selType('modulo',this)">
              <span class="type-opt-name">Módulo habitable</span>
              <span class="type-opt-desc">Viviendas, estudios, oficinas y locales.</span>
              <span class="type-opt-price">USD {rateModulo} <span>/m²</span></span>
            </button>
            <button class="type-opt" id="t-semi" onclick="selType('semi',this)">
              <span class="type-opt-name">Semicubierto</span>
              <span class="type-opt-desc">Cocheras, galerías y semicubiertos.</span>
              <span class="type-opt-price">USD {rateSemi} <span>/m²</span></span>
              <span class="type-opt-note" id="semi-note">Superficie mínima de cálculo: 20 m².</span>
            </button>
          </div>
        </div>
        <div>
          <div class="range-hd">
            <p class="cot-lbl">2 · Superficie</p>
            <div class="range-val"><span id="area-v">48</span> <span>m²</span></div>
          </div>
          <input type="range" id="area-r" min="15" max="200" step="1" value="48" oninput="updateArea(this.value)" />
          <div class="range-ext"><span id="rmin">15 m²</span><span id="rmax">200 m²</span></div>
          <div class="pills" id="pills-c">
            <button class="pill" onclick="setArea(24)">24 m²</button>
            <button class="pill sel" onclick="setArea(48)">48 m²</button>
            <button class="pill" onclick="setArea(80)">80 m²</button>
            <button class="pill" onclick="setArea(120)">120 m²</button>
          </div>
          <p id="semi-min-note" style="display:none;margin-top:12px;font-size:12px;color:var(--accent);">*Cocheras y galerías contemplan un mínimo de 20 m².</p>
        </div>
        <div>
          <p class="cot-lbl">3 · Nivel de terminación</p>
          <div class="finish-opts">
            <button class="finish-opt" onclick="selFinish('esencial',1,this)">
              <span class="finish-opt-name">Esencial</span>
              <span class="finish-opt-desc">Estructura + cerramiento</span>
            </button>
            <button class="finish-opt sel" onclick="selFinish('estandar',1.15,this)">
              <span class="finish-opt-name">Estándar</span>
              <span class="finish-opt-desc">Terminación completa</span>
            </button>
            <button class="finish-opt" onclick="selFinish('premium',1.35,this)">
              <span class="finish-opt-name">Premium</span>
              <span class="finish-opt-desc">Materiales superiores</span>
            </button>
          </div>
        </div>
      </div>
      <div class="cot-result">
        <p class="cr-lbl">Estimación · desde</p>
        <div class="cr-price" id="cr-price">USD 35.328</div>
        <p class="cr-sub" id="cr-sub">USD 736 /m² · valor de referencia + IVA</p>
        <div class="cr-rows">
          <div class="cr-row"><span>Tipo</span><span id="cr-type">Módulo habitable</span></div>
          <div class="cr-row"><span>Superficie</span><span id="cr-area">48 m²</span></div>
          <div class="cr-row"><span>Terminación</span><span id="cr-finish">Estándar</span></div>
        </div>
        <p class="cr-disc">* Estimación automática orientativa. El valor final se define con relevamiento de obra, terreno y logística.</p>
        <a id="cr-wa" href="#" target="_blank" rel="noopener" class="cr-wa" onclick="track('whatsapp_click',{source:'cotizador'})">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
          Solicitar presupuesto real
        </a>
        <a href="https://calendly.com/gambettadiegooscar/30min" target="_blank" rel="noopener" class="cr-visit">Agendar visita al showroom</a>
      </div>
    </div>
  </section>

  <!-- SHOWROOM CTA -->
  <section id="showroom" class="showroom-sec" style="padding:clamp(24px,3.5vw,48px) var(--px);">
    <div class="showroom-box rv">
      <p class="eye" style="color:rgba(245,244,240,.55);">Showroom · San Juan</p>
      <h2>Atención personalizada en Showroom.</h2>
      <p>Reserve un bloque exclusivo de consultoría técnica para conocer nuestro sistema constructivo.</p>
      <a href="https://calendly.com/gambettadiegooscar/30min" target="_blank" rel="noopener" class="btn-showroom">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4" width="18" height="18" rx="3"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        Agendar Cita en Showroom
      </a>
    </div>
  </section>

  <!-- MODAL -->
  <div class="m-ov" id="modal" onclick="handleOv(event)">
    <div class="m-box" onclick="event.stopPropagation()">
      <div class="m-hdr">
        <div class="m-hdr-l">
          <img src="/assets/qbox-logo-ink.webp" alt="qBox" class="m-logo" />
          <span class="m-brand">Calendly</span>
        </div>
        <button class="m-close" onclick="closeModal()">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="m-picker" class="m-body">
        <p class="m-title">Agendar visita al showroom</p>
        <p class="m-sub">Turno de 1 hora · Lunes a Viernes, de 09:00 a 18:00 hs</p>

        <p class="m-sec">Tus datos</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
          <div>
            <label style="font-size:12px;font-weight:600;color:var(--accent);display:block;margin-bottom:5px;">Nombre</label>
            <input id="m-nombre" type="text" placeholder="Ej: María" autocomplete="given-name"
              style="width:100%;padding:11px 14px;border-radius:10px;border:1.5px solid var(--border);background:var(--card);font-family:var(--sans);font-size:14.5px;color:var(--ink);outline:none;transition:.2s;"
              oninput="checkForm()" onfocus="this.style.borderColor='var(--ink)'" onblur="this.style.borderColor='var(--border)'" />
          </div>
          <div>
            <label style="font-size:12px;font-weight:600;color:var(--accent);display:block;margin-bottom:5px;">Apellido</label>
            <input id="m-apellido" type="text" placeholder="Ej: González" autocomplete="family-name"
              style="width:100%;padding:11px 14px;border-radius:10px;border:1.5px solid var(--border);background:var(--card);font-family:var(--sans);font-size:14.5px;color:var(--ink);outline:none;transition:.2s;"
              oninput="checkForm()" onfocus="this.style.borderColor='var(--ink)'" onblur="this.style.borderColor='var(--border)'" />
          </div>
        </div>
        <div style="margin-bottom:22px;">
          <label style="font-size:12px;font-weight:600;color:var(--accent);display:block;margin-bottom:5px;">Correo electrónico</label>
          <input id="m-email" type="email" placeholder="tu@email.com" autocomplete="email"
            style="width:100%;padding:11px 14px;border-radius:10px;border:1.5px solid var(--border);background:var(--card);font-family:var(--sans);font-size:14.5px;color:var(--ink);outline:none;transition:.2s;"
            oninput="checkForm()" onfocus="this.style.borderColor='var(--ink)'" onblur="this.style.borderColor='var(--border)'" />
          <p id="email-err" style="display:none;font-size:12px;color:#c0392b;margin-top:4px;">Ingresá un email válido.</p>
        </div>

        <p class="m-sec">Elegí un día</p>
        <div class="days-g" id="days-g"></div>
        <p class="m-sec">Elegí un horario</p>
        <div class="slots-g" id="slots-g"></div>
        <button class="conf-btn" id="conf-btn" disabled onclick="confirmBook()">Completá tus datos para continuar</button>
      </div>

      <div class="m-done" id="m-done">
        <div class="done-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FAF9F5" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <p class="done-title">¡Visita reservada!</p>
        <p class="done-det" id="done-det"></p>
        <p class="done-hint">Recibirás la confirmación con todos los detalles del turno.</p>
        <button class="btn-p" style="margin:0 auto;display:inline-flex;" onclick="closeModal()">Listo</button>
      </div>
    </div>
  </div>

  <script type="application/json" id="index-data" set:html={JSON.stringify({ rateModulo, rateSemi })}></script>
  <script is:inline>
    /* ===== COTIZADOR ===== */
    const { rateModulo, rateSemi } = JSON.parse(document.getElementById('index-data').textContent);
    const TYPES = {
      modulo: { label: 'Módulo habitable', short: 'Módulo habitable', base: rateModulo, min: 15, max: 200, pills: [24, 48, 80, 120] },
      semi: { label: 'Semicubierto', short: 'Cocheras y galerías', base: rateSemi, min: 20, max: 150, pills: [20, 40, 60, 90] }
    };
    const FINS = {
      esencial: { label: 'Esencial', mult: 1 },
      estandar: { label: 'Estándar', mult: 1.15 },
      premium: { label: 'Premium', mult: 1.35 }
    };
    let st = { type: 'modulo', area: 48, fin: 'estandar' };

    function calcCot() {
      const tc = TYPES[st.type], fc = FINS[st.fin];
      const pm2 = Math.round(tc.base * fc.mult);
      const tot = pm2 * st.area;
      const fmt = (n) => 'USD ' + n.toLocaleString('es-AR');
      document.getElementById('cr-price').textContent = fmt(tot);
      document.getElementById('cr-sub').textContent = fmt(pm2) + ' /m² · valor de referencia + IVA';
      document.getElementById('cr-type').textContent = tc.short;
      document.getElementById('cr-area').textContent = st.area + ' m²';
      document.getElementById('cr-finish').textContent = fc.label;
      const msg = encodeURIComponent('Hola qBox, calculé un proyecto en el cotizador: ' + tc.label + ' · ' + st.area + ' m² · terminación ' + fc.label + ' · estimado ' + fmt(tot) + '. Quiero un presupuesto real.');
      document.getElementById('cr-wa').href = 'https://wa.me/5492644431309?text=' + msg;
      if (window.track) track('cotizador_use', { type: st.type, area: st.area, finish: st.fin });
    }

    function selType(key, btn) {
      st.type = key;
      document.querySelectorAll('.type-opt').forEach((b) => b.classList.remove('sel'));
      btn.classList.add('sel');
      const tc = TYPES[key];
      document.getElementById('area-r').min = tc.min;
      document.getElementById('area-r').max = tc.max;
      document.getElementById('rmin').textContent = tc.min + ' m²';
      document.getElementById('rmax').textContent = tc.max + ' m²';
      st.area = Math.min(Math.max(st.area, tc.min), tc.max);
      document.getElementById('area-r').value = st.area;
      document.getElementById('area-v').textContent = st.area;
      const pc = document.getElementById('pills-c');
      pc.innerHTML = '';
      tc.pills.forEach((v) => { const b = document.createElement('button'); b.className = 'pill' + (st.area === v ? ' sel' : ''); b.textContent = v + ' m²'; b.onclick = () => setArea(v); pc.appendChild(b); });
      document.getElementById('semi-min-note').style.display = key === 'semi' ? 'block' : 'none';
      calcCot();
    }
    function updateArea(v) {
      st.area = parseInt(v);
      document.getElementById('area-v').textContent = v;
      document.querySelectorAll('.pill').forEach((p) => { p.classList.toggle('sel', parseInt(p.textContent) === st.area); });
      calcCot();
    }
    function setArea(v) {
      st.area = v;
      document.getElementById('area-r').value = v;
      document.getElementById('area-v').textContent = v;
      document.querySelectorAll('.pill').forEach((p) => p.classList.toggle('sel', parseInt(p.textContent) === v));
      calcCot();
    }
    function selFinish(key, mult, btn) {
      st.fin = key;
      document.querySelectorAll('.finish-opt').forEach((b) => b.classList.remove('sel'));
      btn.classList.add('sel');
      calcCot();
    }
    calcCot();

    /* ===== VIDEO ===== */
    setTimeout(() => { const v = document.getElementById('hero-vid'); if (v) v.setAttribute('preload', 'auto'); }, 800);

    /* ===== COUNTERS ===== */
    const _co = new IntersectionObserver((es) => { es.forEach((e) => { if (e.isIntersecting) { cnt(e.target); _co.unobserve(e.target); } }); }, { threshold: 0.5 });
    document.querySelectorAll('[data-count]').forEach((el) => _co.observe(el));
    function cnt(el) { const t = +el.dataset.count, s = el.dataset.suffix || '', d = 1300, start = performance.now(); const tick = (n) => { const p = Math.min(1, (n - start) / d); el.textContent = Math.round(t * (1 - Math.pow(1 - p, 3))) + s; if (p < 1) requestAnimationFrame(tick); }; requestAnimationFrame(tick); }

    /* ===== MODAL ===== */
    let selDay = null, selSlot = null;
    function openModal() {
      if (window.track) track('showroom_click', { source: 'modal' });
      document.getElementById('modal').classList.add('open');
      document.body.style.overflow = 'hidden';
      buildDays(); buildSlots(); resetModal();
    }
    function closeModal() {
      document.getElementById('modal').classList.remove('open');
      document.body.style.overflow = '';
      setTimeout(resetModal, 300);
    }
    function handleOv(e) { if (e.target === document.getElementById('modal')) closeModal(); }
    function buildDays() {
      const g = document.getElementById('days-g'); g.innerHTML = '';
      const dn = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];
      const mn = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
      const today = new Date(); let cnt = 0, d = new Date(today); d.setDate(d.getDate() + 1);
      while (cnt < 8) {
        if (d.getDay() >= 1 && d.getDay() <= 5) {
          const key = d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate();
          const lbl = dn[d.getDay()]; const full = lbl + ' ' + d.getDate() + ' ' + mn[d.getMonth()];
          const btn = document.createElement('button'); btn.className = 'day-b'; btn.dataset.key = key; btn.dataset.full = full;
          btn.innerHTML = '<span class="day-top">' + lbl + '</span><span class="day-bot">' + d.getDate() + '</span>';
          btn.onclick = function () { selectDay(this); }; g.appendChild(btn); cnt++;
        }
        d.setDate(d.getDate() + 1);
      }
    }
    function buildSlots() {
      const g = document.getElementById('slots-g'); g.innerHTML = '';
      ['09:00', '10:00', '11:00', '12:00', '14:00', '15:00', '16:00', '17:00', '18:00'].forEach((h) => {
        const b = document.createElement('button'); b.className = 'slot-b'; b.textContent = h;
        b.onclick = function () { selectSlot(this); }; g.appendChild(b);
      });
    }
    function checkForm() {
      const nombre = document.getElementById('m-nombre').value.trim();
      const apellido = document.getElementById('m-apellido').value.trim();
      const email = document.getElementById('m-email').value.trim();
      const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      const errEl = document.getElementById('email-err');
      const btn = document.getElementById('conf-btn');
      errEl.style.display = (email && !emailOk) ? 'block' : 'none';
      if (!nombre) { btn.disabled = true; btn.textContent = 'Ingresá tu nombre para continuar'; return; }
      if (!apellido) { btn.disabled = true; btn.textContent = 'Ingresá tu apellido para continuar'; return; }
      if (!email || !emailOk) { btn.disabled = true; btn.textContent = 'Ingresá un email válido para continuar'; return; }
      if (!selDay) { btn.disabled = true; btn.textContent = 'Elegí un día para continuar'; return; }
      if (!selSlot) { btn.disabled = true; btn.textContent = 'Elegí un horario para continuar'; return; }
      btn.disabled = false;
      btn.textContent = 'Confirmar turno · ' + selDay + ' · ' + selSlot + ' hs';
    }
    function selectDay(btn) {
      document.querySelectorAll('.day-b').forEach((b) => b.classList.remove('sel'));
      btn.classList.add('sel'); selDay = btn.dataset.full; checkForm();
    }
    function selectSlot(btn) {
      document.querySelectorAll('.slot-b').forEach((b) => b.classList.remove('sel'));
      btn.classList.add('sel'); selSlot = btn.textContent; checkForm();
    }
    function confirmBook() {
      const nombre = document.getElementById('m-nombre').value.trim();
      const apellido = document.getElementById('m-apellido').value.trim();
      const email = document.getElementById('m-email').value.trim();
      document.getElementById('m-picker').style.display = 'none';
      document.getElementById('m-done').classList.add('show');
      document.getElementById('done-det').innerHTML =
        'Te esperamos en el showroom el <strong>' + selDay + '</strong> a las <strong>' + selSlot + ' hs</strong>.<br>' +
        '<span style="font-size:14px;color:var(--accent)">Confirmación para ' + nombre + ' ' + apellido + ' · ' + email + '</span>';
    }
    function resetModal() {
      selDay = null; selSlot = null;
      document.getElementById('m-picker').style.display = '';
      document.getElementById('m-done').classList.remove('show');
      document.querySelectorAll('.day-b,.slot-b').forEach((b) => b.classList.remove('sel'));
      ['m-nombre', 'm-apellido', 'm-email'].forEach((id) => document.getElementById(id).value = '');
      document.getElementById('email-err').style.display = 'none';
      const btn = document.getElementById('conf-btn'); btn.disabled = true; btn.textContent = 'Completá tus datos para continuar';
    }
  </script>

