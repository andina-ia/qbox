# Environment variables required by the Vercel serverless functions (api/).
# Set these in Vercel → Project → Settings → Environment Variables.

# Shared admin password (Authorization: Bearer <ADMIN_PASS>) used by
# api/upload.js and api/config.js. It MUST match the password in the Admin panel.
# Keep it secret. There is no default: if unset, saving from the Admin fails.
ADMIN_PASS=qbox2026

# GitHub — the Admin writes site config and uploaded images to the repo via the
# GitHub Contents API. Config lives in src/data/config.json; images in
# public/assets/media/. A commit triggers a Vercel redeploy that publishes the change.
GITHUB_TOKEN=
GITHUB_OWNER=andina-ia
GITHUB_REPO=qbox
GITHUB_BRANCH=main
