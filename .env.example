# Environment variables required by the Vercel serverless functions.
# Set these in Vercel → Project → Settings → Environment Variables.

# Shared admin password (Authorization: Bearer <ADMIN_PASS>) used by
# api/upload.js and api/config.js. Keep it secret; do not hardcode in the client.
ADMIN_PASS=qbox2026

# Supabase — used by api/config.js to read/write site configuration.
SUPABASE_URL=https://xnycltgfyvvguyqkuczo.supabase.co
# service_role key (server-side only, NEVER expose in the client bundle).
SUPABASE_SERVICE_ROLE_KEY=

# GitHub — used by api/upload.js to store uploaded images in the repo.
GITHUB_TOKEN=
GITHUB_OWNER=guadalupelloveras-pixel
GITHUB_REPO=Qbox
